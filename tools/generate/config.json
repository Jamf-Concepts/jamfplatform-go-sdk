{
  "package": "jamfplatform",
  "module": "github.com/Jamf-Concepts/jamfplatform-go-sdk",
  "specDir": "api",
  "specs": [
    {
      "file": "testing/device-inventory.yaml",
      "namespace": "devices",
      "package": "devices",
      "splitByTag": true,
      "specFile": "device_inventory_api.json",
      "operations": [
        {"op": "GET /v1/devices", "name": "ListDevices", "pagination": "hasNext", "params": ["sort:[]string", "filter"]},
        {"op": "GET /v1/devices/{id}", "name": "GetDevice"},
        {"op": "PATCH /v1/devices/{id}", "name": "UpdateDevice"},
        {"op": "DELETE /v1/devices/{id}", "name": "DeleteDevice"},
        {"op": "GET /v1/devices/{id}/applications", "name": "ListDeviceApplications", "pagination": "hasNext", "params": ["sort:[]string", "filter"]},
        {"op": "GET /v1/users/{id}/devices", "name": "ListDevicesForUser", "pagination": "hasNext", "params": ["sort:[]string", "filter"], "pathNames": {"id": "userID"}}
      ]
    },
    {
      "file": "testing/blueprints.json",
      "namespace": "blueprints",
      "package": "blueprints",
      "splitByTag": true,
      "specFile": "blueprints_api.json",
      "operations": [
        {"op": "GET /v1/blueprints", "name": "ListBlueprints", "pagination": "sizeCheck", "params": ["sort:[]string", "search"]},
        {"op": "POST /v1/blueprints", "name": "CreateBlueprint"},
        {"op": "GET /v1/blueprints/{blueprintId}", "name": "GetBlueprint"},
        {"op": "PATCH /v1/blueprints/{blueprintId}", "name": "UpdateBlueprint"},
        {"op": "DELETE /v1/blueprints/{blueprintId}", "name": "DeleteBlueprint"},
        {"op": "POST /v1/blueprints/{blueprintId}/deploy", "name": "DeployBlueprint"},
        {"op": "POST /v1/blueprints/{blueprintId}/undeploy", "name": "UndeployBlueprint"},
        {"op": "GET /v1/blueprints/{blueprintId}/report", "name": "GetBlueprintReport"},
        {"op": "GET /v1/blueprint-components", "name": "ListBlueprintComponents", "pagination": "sizeCheck"},
        {"op": "GET /v1/blueprint-components/{identifier}", "name": "GetBlueprintComponent"}
      ]
    },
    {
      "file": "testing/devicegroups.yaml",
      "namespace": "device-groups",
      "package": "devicegroups",
      "splitByTag": true,
      "specFile": "device_group_inventory_api.json",
      "operations": [
        {"op": "GET /v1/device-groups", "name": "ListDeviceGroups", "pagination": "hasNext", "params": ["sort:[]string", "filter"]},
        {"op": "POST /v1/device-groups", "name": "CreateDeviceGroup"},
        {"op": "GET /v1/device-groups/{id}", "name": "GetDeviceGroup"},
        {"op": "PATCH /v1/device-groups/{id}", "name": "UpdateDeviceGroup", "contentType": "application/json"},
        {"op": "DELETE /v1/device-groups/{id}", "name": "DeleteDeviceGroup"},
        {"op": "GET /v1/device-groups/{id}/members", "name": "ListDeviceGroupMembers", "unwrapResults": "[]string"},
        {"op": "PATCH /v1/device-groups/{id}/members", "name": "UpdateDeviceGroupMembers", "contentType": "application/json"},
        {"op": "GET /v1/devices/{id}/device-groups", "name": "ListDeviceGroupsForDevice", "pathNames": {"id": "deviceID"}, "unwrapResults": "[]DeviceGroupMemberOfRepresentationV1"}
      ]
    },
    {
      "file": "testing/deviceaction.yaml",
      "namespace": "device-actions",
      "package": "deviceactions",
      "splitByTag": true,
      "specFile": "device_management_action_api.json",
      "operations": [
        {"op": "POST /v1/devices/{id}/check-in", "name": "CheckInDevice"},
        {"op": "POST /v1/devices/{id}/erase", "name": "EraseDevice"},
        {"op": "POST /v1/devices/{id}/restart", "name": "RestartDevice"},
        {"op": "POST /v1/devices/{id}/shutdown", "name": "ShutdownDevice"},
        {"op": "POST /v1/devices/{id}/unmanage", "name": "UnmanageDevice"}
      ]
    },
    {
      "file": "testing/declarations.json",
      "namespace": "ddm/report",
      "package": "ddmreport",
      "splitByTag": true,
      "specFile": "declaration_reporting_service.json",
      "operations": [
        {"op": "GET /v1/devices/{deviceId}", "name": "GetDeviceDeclarationReport"},
        {"op": "GET /v1/declarations/{declarationIdentifier}", "name": "ListDeclarationReportClients", "pagination": "totalCount", "pageSizeParam": "size", "params": ["sort:[]string"]}
      ]
    },
    {
      "file": "testing/benchmarks.json",
      "namespace": "compliance-benchmarks",
      "package": "compliancebenchmarks",
      "splitByTag": true,
      "specFile": "compliance_benchmark_engine.json",
      "operations": [
        {"op": "GET /v2/benchmarks", "name": "ListBenchmarks", "version": "v1"},
        {"op": "POST /v2/benchmarks", "name": "CreateBenchmark", "version": "v1"},
        {"op": "GET /v2/benchmarks/{id}", "name": "GetBenchmark", "version": "v1"},
        {"op": "DELETE /v1/benchmarks/{benchmarkId}", "name": "DeleteBenchmark"},
        {"op": "GET /v1/baselines", "name": "ListBaselines"},
        {"op": "GET /v1/rules", "name": "GetBaselineRules", "params": ["baselineId:string:baselineID"]}
      ]
    },
    {
      "file": "testing/benchmarks-report.yaml",
      "namespace": "compliance-benchmarks",
      "package": "compliancebenchmarks",
      "splitByTag": true,
      "specFile": "compliance_benchmarks_reporting_api.json",
      "operations": [
        {"op": "GET /v1/benchmarks/{id}/rules", "name": "ListBenchmarkRulesStats", "pagination": "sizeCheck", "params": ["sort:string", "rule-search:string:ruleSearch"]},
        {"op": "GET /v1/benchmarks/{id}/devices", "name": "ListBenchmarkRuleDevices", "pagination": "sizeCheck", "params": ["rule-id:string:ruleID", "sort:string", "device-search:string:deviceSearch", "rule-result:string:ruleResult"]},
        {"op": "GET /v1/benchmarks/{benchmarkId}/compliance-percentage", "name": "GetBenchmarkCompliancePercentage"}
      ]
    },
    {
      "file": "testing/pro.json",
      "namespace": "pro",
      "package": "pro",
      "splitByTag": true,
      "specFile": "pro_api.json",
      "excludePaths": [
        "POST /v1/auth/token",
        "POST /v1/auth/keep-alive",
        "POST /v1/auth/invalidate-token",
        "GET /auth/current",
        "POST /v1/oauth/token"
      ],
      "operations": [
        {"op": "GET /v1/buildings", "name": "ListBuildingsV1", "pagination": "totalCount", "params": ["sort:[]string", "filter"]},
        {"op": "POST /v1/buildings", "name": "CreateBuildingV1"},
        {"op": "GET /v1/buildings/{id}", "name": "GetBuildingV1"},
        {"op": "PUT /v1/buildings/{id}", "name": "UpdateBuildingV1"},
        {"op": "DELETE /v1/buildings/{id}", "name": "DeleteBuildingV1"},
        {"op": "GET /startup-status", "name": "GetStartupStatus"},
        {"op": "POST /v1/user/change-password", "name": "ChangeUserPasswordV1"},
        {"op": "POST /v1/buildings/export", "name": "ExportBuildingsV1", "params": ["sort:[]string", "filter"]},
        {"op": "POST /v1/icon", "name": "UploadIconV1"}
      ]
    }
  ]
}
