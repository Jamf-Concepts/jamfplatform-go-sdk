{
  "components": {
    "examples": {
      "BenchmarkRulesStatsResponseCSV": {
        "summary": "Example CSV export of benchmark rules stats",
        "value": "CIS Reference Number,Rule Name,Rule ID,Total Passing,Total Failing,Total Unknown,Rule Description\n\"1.1\",\"Ensure Software Update is Updated and Current\",\"system_settings_software_update_current\",10,5,4,\"The system is configured to ensure that Software Update is updated and current.\"\n,\"Ensure Firewall is Enabled\",\"system_settings_firewall_enabled\",5,1,4,\"The system is configured to ensure that the firewall is enabled.\"\n"
      }
    },
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        },
        "description": "Bad request due to invalid parameters"
      },
      "NotFound": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        },
        "description": "The requested resource was not found"
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        },
        "description": "Request unauthorized due to invalid credentials"
      }
    },
    "schemas": {
      "ApiError": {
        "properties": {
          "errors": {
            "items": {
              "properties": {
                "code": {
                  "description": "Error-specific code for troubleshooting",
                  "example": "INVALID_FIELD",
                  "type": "string"
                },
                "description": {
                  "description": "A detailed error message",
                  "example": "Invalid value for field name",
                  "type": "string"
                },
                "field": {
                  "description": "The field that caused the error",
                  "example": "name",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "httpStatus": {
            "description": "HTTP status of the response",
            "example": 400,
            "maximum": 599,
            "minimum": 100,
            "type": "integer"
          },
          "traceId": {
            "description": "Unique identifier for the request, useful for tracing and debugging",
            "example": "7AF8CEAB-F7EE-45C3-B573-38A4F93C6E7E",
            "type": "string"
          }
        },
        "required": [
          "httpStatus",
          "errors",
          "traceId"
        ],
        "type": "object"
      },
      "BenchmarkRuleDevicesResponse": {
        "description": "Representation of devices for a benchmark rule. Used for drill-down view controller",
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/DeviceRuleResult"
            },
            "readOnly": true,
            "type": "array"
          },
          "totalCount": {
            "example": 3,
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
          }
        },
        "readOnly": true,
        "type": "object"
      },
      "BenchmarkRulesStatsResponse": {
        "description": "Representation of rules results for whole benchmark. Used for top-level view controller",
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/RuleResult"
            },
            "readOnly": true,
            "type": "array"
          },
          "totalCount": {
            "example": 3,
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
          }
        },
        "type": "object"
      },
      "CompliancePercentage": {
        "properties": {
          "compliancePercentage": {
            "example": 82.7,
            "format": "float",
            "maximum": 100,
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "compliancePercentage"
        ],
        "type": "object"
      },
      "DeviceRuleResult": {
        "properties": {
          "deviceId": {
            "description": "Device Platform ID",
            "example": "641dcad2-695f-456b-83e7-ec58f2e14ec6",
            "minLength": 1,
            "type": "string"
          },
          "deviceName": {
            "example": "John's MacBook Pro",
            "nullable": true,
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/RuleResultState"
          }
        },
        "required": [
          "deviceId",
          "state"
        ],
        "type": "object"
      },
      "RuleResult": {
        "properties": {
          "discussion": {
            "example": "The information system _IS_ configured to allow administrators to modify security settings and system attributes.",
            "type": "string"
          },
          "failed": {
            "example": 40,
            "minimum": 0,
            "type": "integer"
          },
          "numberOfDevices": {
            "example": 200,
            "minimum": 0,
            "type": "integer"
          },
          "passPercentage": {
            "example": 75,
            "format": "float",
            "minimum": 0,
            "type": "number"
          },
          "passed": {
            "example": 150,
            "minimum": 0,
            "type": "integer"
          },
          "ruleId": {
            "example": "supplemental_password_policy",
            "minLength": 1,
            "type": "string"
          },
          "ruleNumber": {
            "description": "Rule number in the benchmark, if applicable. E.g. CIS numbers like '2.5.1.1'.",
            "example": "2.5.1.1",
            "type": "string"
          },
          "ruleTitle": {
            "example": "Password Policy Supplemental",
            "minLength": 1,
            "type": "string"
          },
          "unknown": {
            "example": 10,
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "ruleId",
          "ruleTitle",
          "passed",
          "failed",
          "unknown",
          "passPercentage",
          "numberOfDevices"
        ],
        "type": "object"
      },
      "RuleResultState": {
        "enum": [
          "PASSED",
          "FAILED",
          "UNKNOWN"
        ],
        "type": "string"
      }
    }
  },
  "info": {
    "title": "Compliance Benchmarks Reporting API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1/benchmarks/{benchmarkId}/compliance-percentage": {
      "get": {
        "description": "Calculates and returns the overall compliance percentage for a specific benchmark report as sum of device compliance scores divided by number of devices",
        "operationId": "v1GetBenchmarkCompliancePercentage",
        "parameters": [
          {
            "description": "Tenant's benchmark ID",
            "in": "path",
            "name": "benchmarkId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompliancePercentage"
                }
              }
            },
            "description": "Successful response with compliance percentage"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "description": "Benchmark has no applicable rules for reporting calculations"
          }
        },
        "summary": "Get compliance percentage for a benchmark report",
        "tags": [
          "benchmark-compliance-controller"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:compliance-benchmarks",
          "read:pro:compliance-benchmarks"
        ]
      }
    },
    "/v1/benchmarks/{id}/devices": {
      "get": {
        "description": "Provides devices filtered report for a specific benchmark rule",
        "operationId": "v1GetDevicesForBenchmarkRule",
        "parameters": [
          {
            "description": "Tenant's benchmark ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "rule-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Search devices with matching device name or device ID",
            "in": "query",
            "name": "device-search",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "rule-result",
            "schema": {
              "$ref": "#/components/schemas/RuleResultState"
            }
          },
          {
            "description": "Page number (0-based index, default is 0)",
            "in": "query",
            "name": "page",
            "schema": {
              "default": 0,
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Number of results per page (default is 100)",
            "in": "query",
            "name": "page-size",
            "schema": {
              "default": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Sort order of result (e.g., 'deviceName:asc', 'ruleResult:desc'). Supports chained sorting like 'deviceName,ruleResult:desc'. Ascending order is default and in such a case doesn't require to be specified.",
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "ruleResult:desc",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BenchmarkRuleDevicesResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        },
        "summary": "Get devices for a benchmark report rule",
        "tags": [
          "benchmark-rule-devices-controller"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:compliance-benchmarks",
          "read:pro:compliance-benchmarks"
        ]
      }
    },
    "/v1/benchmarks/{id}/rules": {
      "get": {
        "description": "Provides benchmark rules stats for a specific benchmark",
        "operationId": "v1GetBenchmarkRulesStats",
        "parameters": [
          {
            "description": "Tenant's benchmark ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "string to search in rule title and rule id",
            "in": "query",
            "name": "rule-search",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Page number (0-based index, default is 0)",
            "in": "query",
            "name": "page",
            "schema": {
              "default": 0,
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Number of results per page (default is 500)",
            "in": "query",
            "name": "page-size",
            "schema": {
              "default": 500,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Sort order of result (e.g., 'ruleTitle:asc', 'passed:desc', 'failed:desc', 'unknown:desc'). Supports chained sorting like 'ruleId,passed:desc'. Ascending order is default and in such a case doesn't require to be specified, such as 'ruleNumber,ruleTitle'.",
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "ruleNumber,ruleTitle",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BenchmarkRulesStatsResponse"
                }
              }
            },
            "description": "Successful response with benchmark rules list"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        },
        "summary": "Get benchmark rules for a tenant",
        "tags": [
          "benchmark-rules-stats-controller"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:compliance-benchmarks",
          "read:pro:compliance-benchmarks"
        ]
      }
    }
  }
}
