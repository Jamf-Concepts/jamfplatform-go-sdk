{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "Bearer token": []
    }
  ],
  "tags": [
    {
      "name": "Software updates",
      "description": "Software updates component"
    }
  ],
  "paths": {
    "/v1/components/sw-update/validate": {
      "post": {
        "tags": [
          "Software updates"
        ],
        "summary": "Validate component configuration",
        "description": "Validate component configuration and return validation errors",
        "operationId": "validate",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          }
        }
      }
    },
    "/v1/components/sw-update/translate": {
      "post": {
        "tags": [
          "Software updates"
        ],
        "summary": "Translate component configuration",
        "description": "Translate component configuration to deployable objects and return identifier of generated objects.",
        "operationId": "translate",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/components/sw-update/cleanup": {
      "post": {
        "tags": [
          "Software updates"
        ],
        "summary": "Cleanup component data",
        "description": "Cleanup component data that were created during translation.",
        "operationId": "cleanup",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CleanupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ValidationError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error specific code",
            "example": "NOT_NULL"
          },
          "path": {
            "type": "string",
            "description": "Property path with validation error",
            "example": "configuration.targetOSVersion"
          },
          "message": {
            "type": "string",
            "description": "A general description of error for troubleshooting/debugging",
            "example": "must not be null"
          }
        },
        "required": [
          "code",
          "message",
          "path"
        ]
      },
      "ValidationResult": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "description": "An array of validation errors",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        },
        "required": [
          "errors"
        ]
      },
      "DetailsUrl": {
        "type": "object",
        "properties": {
          "Value": {
            "type": "string",
            "format": "uri",
            "description": "URL of a web page with the details about the enforced update"
          },
          "Included": {
            "type": "boolean",
            "default": false,
            "description": "Controls whether this control should be used."
          }
        }
      },
      "SwUpdateAutomaticConfiguration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SwUpdateConfiguration"
          },
          {
            "type": "object",
            "properties": {
              "enforceAfterDays": {
                "type": "integer",
                "format": "int32",
                "description": "The number of days after the OS update release",
                "example": 14,
                "maximum": 30,
                "minimum": 0
              },
              "deploymentTime": {
                "type": "string",
                "description": "The device local time (HH:MM) when should be the update installed",
                "example": "16:00"
              },
              "detailsURL": {
                "$ref": "#/components/schemas/DetailsUrl"
              },
              "strategy": {
                "type": "string",
                "default": "LATEST",
                "description": "Strategy for enforcing OS updates. 'LATEST' enforces the newest available version, 'SEMANTIC' applies semantic versioning rules to determine update enforcement",
                "enum": [
                  "LATEST",
                  "SEMANTIC"
                ],
                "example": "LATEST"
              },
              "rules": {
                "$ref": "#/components/schemas/UpdateRules"
              },
              "enforcementType": {
                "type": "string",
                "const": "AUTOMATIC",
                "enum": [
                  "MANUAL",
                  "AUTOMATIC"
                ]
              }
            }
          }
        ],
        "required": [
          "enforcementType"
        ]
      },
      "SwUpdateConfiguration": {
        "type": "object",
        "discriminator": {
          "propertyName": "enforcementType"
        },
        "properties": {
          "enforcementType": {
            "type": "string",
            "description": "Type of the enforcement",
            "enum": [
              "MANUAL",
              "AUTOMATIC"
            ]
          }
        },
        "required": [
          "enforcementType"
        ]
      },
      "SwUpdateManualConfiguration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SwUpdateConfiguration"
          },
          {
            "type": "object",
            "properties": {
              "targetOSVersion": {
                "type": "string",
                "description": "Target OS version",
                "pattern": "^[1-9]\\d?(?:\\.(?:\\d|[1-9]\\d)){1,2}$"
              },
              "targetLocalDateTime": {
                "type": "string",
                "format": "date-time",
                "description": "Local time of the device until which update must be performed",
                "example": "2025-07-10T10:45:06.809"
              },
              "detailsURL": {
                "$ref": "#/components/schemas/DetailsUrl"
              },
              "enforcementType": {
                "type": "string",
                "const": "MANUAL",
                "enum": [
                  "MANUAL",
                  "AUTOMATIC"
                ]
              }
            }
          }
        ],
        "required": [
          "enforcementType",
          "targetLocalDateTime",
          "targetOSVersion"
        ]
      },
      "UpdateRule": {
        "type": "object",
        "properties": {
          "enforceAfterDays": {
            "type": "integer",
            "format": "int32",
            "description": "The number of days after the OS update release",
            "example": 14,
            "maximum": 30,
            "minimum": 0
          },
          "deploymentTime": {
            "type": "string",
            "description": "The device local time (HH:MM) when should be the update installed",
            "example": "16:00"
          }
        },
        "required": [
          "deploymentTime",
          "enforceAfterDays"
        ]
      },
      "UpdateRules": {
        "type": "object",
        "properties": {
          "minor": {
            "$ref": "#/components/schemas/UpdateRule"
          }
        },
        "required": [
          "minor"
        ]
      },
      "ValidationRequest": {
        "type": "object",
        "properties": {
          "configuration": {
            "description": "Component configuration",
            "oneOf": [
              {
                "$ref": "#/components/schemas/SwUpdateAutomaticConfiguration"
              },
              {
                "$ref": "#/components/schemas/SwUpdateManualConfiguration"
              }
            ]
          }
        },
        "required": [
          "configuration"
        ]
      },
      "DeployableObjectIdentifier": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Deployable object type",
            "enum": [
              "DSS"
            ]
          },
          "id": {
            "type": "string",
            "description": "Deployable object ID",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "type"
        ]
      },
      "TranslateRequest": {
        "type": "object",
        "properties": {
          "configuration": {
            "description": "Component configuration",
            "oneOf": [
              {
                "$ref": "#/components/schemas/SwUpdateAutomaticConfiguration"
              },
              {
                "$ref": "#/components/schemas/SwUpdateManualConfiguration"
              }
            ]
          },
          "currentDeployableObjects": {
            "type": "array",
            "description": "Currently existing deployable objects for this component",
            "items": {
              "$ref": "#/components/schemas/DeployableObjectIdentifier"
            }
          }
        },
        "required": [
          "configuration"
        ]
      },
      "CreatedDeployableObject": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Deployable object type",
            "enum": [
              "DSS"
            ]
          },
          "id": {
            "type": "string",
            "description": "Deployable object ID",
            "minLength": 1
          },
          "versionHash": {
            "type": "string",
            "description": "Deployable object version hash",
            "minLength": 1
          },
          "predicate": {
            "description": "Predicate determining applicability of this deployable object",
            "oneOf": [
              {
                "$ref": "#/components/schemas/LiteralPredicate"
              }
            ]
          }
        },
        "required": [
          "id",
          "type",
          "versionHash"
        ]
      },
      "LiteralPredicate": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Predicate"
          },
          {
            "type": "object",
            "properties": {
              "expression": {
                "type": "string"
              }
            }
          }
        ],
        "required": [
          "expression",
          "type"
        ]
      },
      "Predicate": {
        "type": "object",
        "discriminator": {
          "propertyName": "type"
        },
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "LITERAL_EXPRESSION"
            ]
          }
        },
        "required": [
          "type"
        ]
      },
      "TranslateResponse": {
        "type": "object",
        "properties": {
          "deployableObjects": {
            "type": "array",
            "description": "Created deployable objects",
            "items": {
              "$ref": "#/components/schemas/CreatedDeployableObject"
            }
          }
        },
        "required": [
          "deployableObjects"
        ]
      },
      "CleanupRequest": {
        "type": "object",
        "properties": {
          "deployableObjects": {
            "type": "array",
            "description": "Existing deployable objects for this component",
            "items": {
              "$ref": "#/components/schemas/DeployableObjectIdentifier"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer token": {
        "type": "http",
        "scheme": "Bearer"
      }
    }
  }
}