{
  "components": {
    "parameters": {
      "tenantId": {
        "description": "The tenant UUID identifier",
        "in": "path",
        "name": "tenantId",
        "required": true,
        "schema": {
          "example": "e77c1408-10c8-4007-b177-abc9157fbcaa",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        },
        "description": "Bad request due to invalid parameters"
      }
    },
    "schemas": {
      "ApiError": {
        "properties": {
          "errors": {
            "items": {
              "properties": {
                "code": {
                  "description": "Error-specific code for troubleshooting",
                  "example": "INVALID_FIELD",
                  "type": "string"
                },
                "description": {
                  "description": "A detailed error message",
                  "example": "Invalid value for field name",
                  "type": "string"
                },
                "field": {
                  "description": "The field that caused the error",
                  "example": "name",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "httpStatus": {
            "description": "HTTP status of the response",
            "example": 400,
            "maximum": 599,
            "minimum": 100,
            "type": "integer"
          },
          "traceId": {
            "description": "Unique identifier for the request, useful for tracing and debugging",
            "example": "7AF8CEAB-F7EE-45C3-B573-38A4F93C6E7E",
            "type": "string"
          }
        },
        "required": [
          "httpStatus",
          "errors",
          "traceId"
        ],
        "type": "object"
      },
      "BaselineInfo": {
        "properties": {
          "baselineId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "ruleCount": {
            "format": "int32",
            "type": "integer"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "baselineId",
          "description",
          "id",
          "ruleCount",
          "title"
        ],
        "type": "object"
      },
      "BaselinesResponse": {
        "properties": {
          "baselines": {
            "items": {
              "$ref": "#/components/schemas/BaselineInfo"
            },
            "type": "array"
          }
        },
        "required": [
          "baselines"
        ],
        "type": "object"
      },
      "BenchmarkRequestV2": {
        "properties": {
          "description": {
            "description": "A detailed description of the benchmark",
            "maxLength": 1000,
            "type": "string"
          },
          "enforcementMode": {
            "description": "The enforcement mode for this benchmark",
            "enum": [
              "MONITOR",
              "MONITOR_AND_ENFORCE"
            ],
            "type": "string"
          },
          "rules": {
            "description": "The rules that make up this benchmark",
            "items": {
              "$ref": "#/components/schemas/RuleRequest"
            },
            "minLength": 1,
            "type": "array"
          },
          "sourceBaselineId": {
            "description": "The identifier of the source baseline from which this benchmark is derived",
            "minLength": 1,
            "type": "string"
          },
          "sources": {
            "description": "The sources used to create this benchmark",
            "items": {
              "$ref": "#/components/schemas/Source"
            },
            "minLength": 1,
            "type": "array"
          },
          "target": {
            "$ref": "#/components/schemas/TargetV2"
          },
          "title": {
            "description": "A short, descriptive name for the benchmark",
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "enforcementMode",
          "rules",
          "sourceBaselineId",
          "sources",
          "target",
          "title"
        ],
        "type": "object"
      },
      "BenchmarkResponseV2": {
        "properties": {
          "baselineId": {
            "type": "string"
          },
          "benchmarkId": {
            "type": "string"
          },
          "canSwitchToEnforce": {
            "type": "boolean"
          },
          "deleted": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "enforcementMode": {
            "enum": [
              "MONITOR",
              "MONITOR_AND_ENFORCE"
            ],
            "type": "string"
          },
          "lastUpdatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "rules": {
            "items": {
              "$ref": "#/components/schemas/RuleInfo"
            },
            "type": "array"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/Source"
            },
            "type": "array"
          },
          "target": {
            "$ref": "#/components/schemas/TargetV2"
          },
          "tenantId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updateAvailable": {
            "type": "boolean"
          }
        },
        "required": [
          "baselineId",
          "benchmarkId",
          "canSwitchToEnforce",
          "deleted",
          "enforcementMode",
          "lastUpdatedAt",
          "rules",
          "sources",
          "target",
          "tenantId",
          "title",
          "updateAvailable"
        ],
        "type": "object"
      },
      "BenchmarkRuleDevicesResponse": {
        "description": "Representation of devices for a benchmark rule. Used for drill-down view controller",
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/DeviceRuleResult"
            },
            "readOnly": true,
            "type": "array"
          },
          "totalCount": {
            "example": 3,
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
          }
        },
        "readOnly": true,
        "type": "object"
      },
      "BenchmarkRulesStatsResponse": {
        "description": "Representation of rules results for whole benchmark. Used for top-level view controller",
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/RuleResult"
            },
            "readOnly": true,
            "type": "array"
          },
          "totalCount": {
            "example": 3,
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
          }
        },
        "type": "object"
      },
      "BenchmarkV2": {
        "properties": {
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "modified": {
            "type": "boolean"
          },
          "syncState": {
            "enum": [
              "SYNCED",
              "PENDING",
              "FAILED",
              "DELETING",
              "DELETE_FAILED"
            ],
            "type": "string"
          },
          "target": {
            "$ref": "#/components/schemas/TargetV2"
          },
          "title": {
            "type": "string"
          },
          "updateAvailable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "modified",
          "syncState",
          "target",
          "title",
          "updateAvailable"
        ],
        "type": "object"
      },
      "BenchmarksResponseV2": {
        "properties": {
          "benchmarks": {
            "items": {
              "$ref": "#/components/schemas/BenchmarkV2"
            },
            "type": "array"
          }
        },
        "required": [
          "benchmarks"
        ],
        "type": "object"
      },
      "CompliancePercentage": {
        "properties": {
          "compliancePercentage": {
            "example": 82.7,
            "format": "float",
            "maximum": 100,
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "compliancePercentage"
        ],
        "type": "object"
      },
      "DeviceRuleResult": {
        "properties": {
          "deviceId": {
            "description": "Device Platform ID",
            "example": "641dcad2-695f-456b-83e7-ec58f2e14ec6",
            "minLength": 1,
            "type": "string"
          },
          "deviceName": {
            "example": "John's MacBook Pro",
            "type": [
              "string",
              "null"
            ]
          },
          "state": {
            "$ref": "#/components/schemas/RuleResultState"
          }
        },
        "required": [
          "deviceId",
          "state"
        ],
        "type": "object"
      },
      "OdvRecommendation": {
        "properties": {
          "hint": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "OdvRequest": {
        "properties": {
          "value": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "value"
        ],
        "type": "object"
      },
      "OrganizationDefinedValue": {
        "properties": {
          "hint": {
            "type": "string"
          },
          "placeholder": {
            "type": "string"
          },
          "type": {
            "enum": [
              "INTEGER",
              "STRING",
              "ENUM",
              "REGEX"
            ],
            "type": "string"
          },
          "validation": {
            "$ref": "#/components/schemas/ValidationConstraints"
          },
          "value": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "value"
        ],
        "type": "object"
      },
      "OsInfo": {
        "properties": {
          "managementType": {
            "enum": [
              "MANAGED",
              "BYOD"
            ],
            "type": "string"
          },
          "osType": {
            "enum": [
              "MAC_OS",
              "IOS"
            ],
            "type": "string"
          },
          "osVersion": {
            "format": "int32",
            "type": "integer"
          }
        },
        "required": [
          "managementType",
          "osType",
          "osVersion"
        ],
        "type": "object"
      },
      "OsSpecificRuleInfo": {
        "properties": {
          "description": {
            "type": "string"
          },
          "odv": {
            "$ref": "#/components/schemas/OdvRecommendation"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "description",
          "title"
        ],
        "type": "object"
      },
      "RuleInfo": {
        "properties": {
          "description": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "odv": {
            "$ref": "#/components/schemas/OrganizationDefinedValue"
          },
          "osSpecificDefaults": {
            "additionalProperties": {
              "$ref": "#/components/schemas/OsSpecificRuleInfo"
            },
            "type": "object"
          },
          "references": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "reportable": {
            "type": "boolean"
          },
          "ruleRelation": {
            "$ref": "#/components/schemas/RuleRelation"
          },
          "sectionName": {
            "type": "string"
          },
          "smartCard": {
            "type": "boolean"
          },
          "supportedOs": {
            "items": {
              "$ref": "#/components/schemas/OsInfo"
            },
            "type": "array",
            "uniqueItems": true
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "description",
          "enabled",
          "id",
          "osSpecificDefaults",
          "sectionName",
          "supportedOs",
          "title"
        ],
        "type": "object"
      },
      "RuleRelation": {
        "properties": {
          "conflictsWith": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "defaultDisabled": {
            "type": "boolean"
          },
          "dependsOn": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "RuleRequest": {
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "odv": {
            "$ref": "#/components/schemas/OdvRequest"
          }
        },
        "required": [
          "enabled",
          "id"
        ],
        "type": "object"
      },
      "RuleResult": {
        "properties": {
          "discussion": {
            "example": "The information system _IS_ configured to allow administrators to modify security settings and system attributes.",
            "type": "string"
          },
          "failed": {
            "example": 40,
            "minimum": 0,
            "type": "integer"
          },
          "numberOfDevices": {
            "example": 200,
            "minimum": 0,
            "type": "integer"
          },
          "passPercentage": {
            "example": 75,
            "format": "float",
            "minimum": 0,
            "type": "number"
          },
          "passed": {
            "example": 150,
            "minimum": 0,
            "type": "integer"
          },
          "ruleId": {
            "example": "supplemental_password_policy",
            "minLength": 1,
            "type": "string"
          },
          "ruleNumber": {
            "description": "Rule number in the benchmark, if applicable. E.g. CIS numbers like '2.5.1.1'.",
            "example": "2.5.1.1",
            "type": "string"
          },
          "ruleTitle": {
            "example": "Password Policy Supplemental",
            "minLength": 1,
            "type": "string"
          },
          "unknown": {
            "example": 10,
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "ruleId",
          "ruleTitle",
          "passed",
          "failed",
          "unknown",
          "passPercentage",
          "numberOfDevices"
        ],
        "type": "object"
      },
      "RuleResultState": {
        "enum": [
          "PASSED",
          "FAILED",
          "UNKNOWN"
        ],
        "type": "string"
      },
      "Source": {
        "properties": {
          "branch": {
            "minLength": 1,
            "type": "string"
          },
          "revision": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "branch",
          "revision"
        ],
        "type": "object"
      },
      "SourcedRules": {
        "properties": {
          "rules": {
            "items": {
              "$ref": "#/components/schemas/RuleInfo"
            },
            "type": "array"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/Source"
            },
            "type": "array"
          }
        },
        "required": [
          "rules",
          "sources"
        ],
        "type": "object"
      },
      "TargetV2": {
        "properties": {
          "deviceGroups": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "deviceGroups"
        ],
        "type": "object"
      },
      "ValidationConstraints": {
        "properties": {
          "enumValues": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "max": {
            "format": "int32",
            "type": "integer"
          },
          "min": {
            "format": "int32",
            "type": "integer"
          },
          "regex": {
            "type": "string"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "description": "JWT Bearer token authentication. Obtain a token from the Jamf API Gateway.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Jamf Developer",
      "url": "https://developer.jamf.com"
    },
    "description": "Jamf Compliance Benchmarks API allows you to manage, enforce, and validate compliance on Apple devices",
    "termsOfService": "https://www.jamf.com/developer-resources/api-license-agreement/",
    "title": "Jamf Compliance Benchmarks API - Beta",
    "version": "latest"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/tenant/{tenantId}/baselines": {
      "get": {
        "description": "Return list of the mSCP baselines allowed for the Compliance benchmarks\n\n**Required Permissions:** `read:pro:compliance-benchmarks`",
        "operationId": "getBaselines",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaselinesResponse"
                }
              }
            },
            "description": "Successful operation result"
          },
          "401": {
            "description": "Unauthorized request"
          },
          "403": {
            "description": "Insufficient permissions"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Return list of the mSCP baselines",
        "tags": [
          "baselines"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:compliance-benchmarks"
        ]
      }
    },
    "/v1/tenant/{tenantId}/benchmarks": {
      "get": {
        "description": "Return list of tenant benchmarks (if any)\n\n**Required Permissions:** `read:pro:compliance-benchmarks`",
        "operationId": "getTenantBenchmarks",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BenchmarksResponseV2"
                }
              }
            },
            "description": "Successful operation result"
          },
          "401": {
            "description": "Unauthorized request"
          },
          "403": {
            "description": "Insufficient permissions"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Return list of tenant benchmarks",
        "tags": [
          "benchmarks"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:compliance-benchmarks"
        ]
      },
      "post": {
        "description": "Create a new benchmark from provided benchmark request and deploy associated artifacts to the MDM\n\n**Required Permissions:** `create:pro:compliance-benchmarks`",
        "operationId": "postBenchmark",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BenchmarkRequestV2"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BenchmarkResponseV2"
                }
              }
            },
            "description": "Successful operation result"
          },
          "400": {
            "description": "Invalid benchmark request"
          },
          "401": {
            "description": "Unauthorized request"
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "409": {
            "description": "Benchmark with the same title exists already or database write conflict occurred"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create a new benchmark from provided benchmark request",
        "tags": [
          "benchmarks"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "create:pro:compliance-benchmarks"
        ]
      }
    },
    "/v1/tenant/{tenantId}/benchmarks/{id}": {
      "delete": {
        "description": "Remove benchmark with given benchmark ID and remove associated draft (if any) and artifacts from the MDM\n\n**Required Permissions:** `delete:pro:compliance-benchmarks`",
        "operationId": "deleteBenchmark",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful operation result"
          },
          "400": {
            "description": "Invalid benchmark request or missing benchmark ID"
          },
          "401": {
            "description": "Unauthorized request"
          },
          "403": {
            "description": "Insufficient permissions"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Remove benchmark with given benchmark ID",
        "tags": [
          "benchmarks"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "delete:pro:compliance-benchmarks"
        ]
      },
      "get": {
        "description": "Return benchmark for given benchmark ID (if exists)\n\n**Required Permissions:** `read:pro:compliance-benchmarks`",
        "operationId": "getBenchmark",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BenchmarkResponseV2"
                }
              }
            },
            "description": "Successful operation result"
          },
          "400": {
            "description": "Missing benchmark ID"
          },
          "401": {
            "description": "Unauthorized request"
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Benchmark not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Return benchmark for given benchmark ID",
        "tags": [
          "benchmarks"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:compliance-benchmarks"
        ]
      }
    },
    "/v1/tenant/{tenantId}/benchmarks/{id}/compliance-percentage": {
      "get": {
        "description": "Calculate and return the overall compliance percentage for a specific benchmark report as sum of device compliance scores divided by number of devices\n\n**Required Permissions:** `read:pro:compliance-benchmarks`",
        "operationId": "v1GetBenchmarkCompliancePercentage",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Tenant's benchmark ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompliancePercentage"
                }
              }
            },
            "description": "Successful response with compliance percentage"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "description": "Benchmark has no applicable rules for reporting calculations"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get compliance percentage for a benchmark report",
        "tags": [
          "benchmark-reports"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:compliance-benchmarks"
        ]
      }
    },
