{
  "components": {
    "schemas": {
      "AppInstallerAppRef": {
        "properties": {
          "iconUrl": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "titleName": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "AppInstallerComputerStatuses": {
        "properties": {
          "available": {
            "type": "integer"
          },
          "failed": {
            "type": "integer"
          },
          "inProgress": {
            "type": "integer"
          },
          "installed": {
            "type": "integer"
          },
          "unqualified": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "AppInstallerDeployment": {
        "description": "Single-item shape for App Installer deployment (used for GET by id,\nPOST create, PUT update). References to other resources are flat IDs\nrather than nested objects.\n",
        "properties": {
          "appTitleId": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          },
          "deploymentType": {
            "enum": [
              "INSTALL_AUTOMATICALLY",
              "SELF_SERVICE"
            ],
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "installPredefinedConfigProfiles": {
            "type": "boolean"
          },
          "latestAvailableVersion": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "notificationSettings": {
            "$ref": "#/components/schemas/AppInstallerNotificationSettings"
          },
          "selectedVersion": {
            "type": "string"
          },
          "selfServiceSettings": {
            "$ref": "#/components/schemas/AppInstallerSelfServiceSettings"
          },
          "siteId": {
            "type": "string"
          },
          "smartGroupId": {
            "type": "string"
          },
          "titleAvailableInAis": {
            "type": "boolean"
          },
          "triggerAdminNotifications": {
            "type": "boolean"
          },
          "updateBehavior": {
            "enum": [
              "AUTOMATIC",
              "MANUAL"
            ],
            "type": "string"
          },
          "versionRemoved": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "AppInstallerDeploymentHrefResponse": {
        "properties": {
          "href": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "AppInstallerDeploymentListEntry": {
        "description": "List-view of an App Installer deployment. The server expands site,\ncategory, smartGroup, and app into nested objects for the list\nendpoint; single-item GET / POST / PUT returns the flat-ID shape\n(AppInstallerDeployment).\n",
        "properties": {
          "app": {
            "$ref": "#/components/schemas/AppInstallerAppRef"
          },
          "category": {
            "$ref": "#/components/schemas/AppInstallerNamedRef"
          },
          "computerStatuses": {
            "$ref": "#/components/schemas/AppInstallerComputerStatuses"
          },
          "deploymentType": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "latestAvailableVersion": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "selectedVersion": {
            "type": "string"
          },
          "site": {
            "$ref": "#/components/schemas/AppInstallerNamedRef"
          },
          "smartGroup": {
            "$ref": "#/components/schemas/AppInstallerNamedRef"
          },
          "updateBehavior": {
            "type": "string"
          },
          "versionRemoved": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "AppInstallerDeploymentSearchResults": {
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/AppInstallerDeploymentListEntry"
            },
            "type": "array"
          },
          "totalCount": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "AppInstallerNamedRef": {
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "AppInstallerNotificationSettings": {
        "properties": {
          "completeMessage": {
            "nullable": true,
            "type": "string"
          },
          "deadline": {
            "nullable": true,
            "type": "integer"
          },
          "deadlineMessage": {
            "nullable": true,
            "type": "string"
          },
          "notificationInterval": {
            "nullable": true,
            "type": "integer"
          },
          "notificationMessage": {
            "nullable": true,
            "type": "string"
          },
          "quitDelay": {
            "nullable": true,
            "type": "integer"
          },
          "relaunch": {
            "nullable": true,
            "type": "boolean"
          },
          "suppress": {
            "nullable": true,
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "AppInstallerSelfServiceSettings": {
        "properties": {
          "categories": {
            "items": {
              "$ref": "#/components/schemas/AppInstallerNamedRef"
            },
            "type": "array"
          },
          "description": {
            "nullable": true,
            "type": "string"
          },
          "forceViewDescription": {
            "type": "boolean"
          },
          "includeInComplianceCategory": {
            "type": "boolean"
          },
          "includeInFeaturedCategory": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "AppInstallerTitle": {
        "properties": {
          "architecture": {
            "type": "string"
          },
          "availabilityDate": {
            "type": "string"
          },
          "bundleId": {
            "type": "string"
          },
          "iconUrl": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "installationPathShared": {
            "type": "boolean"
          },
          "language": {
            "type": "string"
          },
          "minimumOsVersion": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "shortVersion": {
            "type": "string"
          },
          "sizeInBytes": {
            "type": "integer"
          },
          "titleName": {
            "description": "Display name of the application.",
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "AppInstallerTitleSearchResults": {
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/AppInstallerTitle"
            },
            "type": "array"
          },
          "totalCount": {
            "type": "integer"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Jamf App Installer catalog: browse available titles from the Jamf App\nCatalog and manage per-tenant deployment configurations. The underlying\nendpoints are live on `/v1/app-installers/*` but aren't published in\nJamf's public pro.json spec — this file is the self-contained schema.\n",
    "title": "Jamf Pro API - App Installers (Jamf App Catalog)",
    "version": "0.1.0"
  },
  "openapi": "3.0.1",
  "paths": {
    "/v1/app-installers/deployments": {
      "get": {
        "description": "Paginated list of deployed App Installer configurations.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerDeploymentSearchResults"
                }
              }
            },
            "description": "Successful response"
          }
        },
        "summary": "Get all App Installer deployments",
        "tags": [
          "app-installer-deployments"
        ]
      },
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppInstallerDeployment"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerDeploymentHrefResponse"
                }
              }
            },
            "description": "Deployment created"
          }
        },
        "summary": "Create an App Installer deployment",
        "tags": [
          "app-installer-deployments"
        ]
      }
    },
    "/v1/app-installers/deployments/{id}": {
      "delete": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deployment deleted"
          }
        },
        "summary": "Delete an App Installer deployment",
        "tags": [
          "app-installer-deployments"
        ]
      },
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerDeployment"
                }
              }
            },
            "description": "Successful response"
          },
          "404": {
            "description": "Deployment not found"
          }
        },
        "summary": "Get an App Installer deployment by ID",
        "tags": [
          "app-installer-deployments"
        ]
      },
      "put": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppInstallerDeployment"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerDeployment"
                }
              }
            },
            "description": "Deployment updated"
          }
        },
        "summary": "Update an App Installer deployment",
        "tags": [
          "app-installer-deployments"
        ]
      }
    },
    "/v1/app-installers/titles": {
      "get": {
        "description": "Paginated list of App Installer titles available in the Jamf App Catalog.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerTitleSearchResults"
                }
              }
            },
            "description": "Successful response"
          }
        },
        "summary": "Get all available App Installer titles",
        "tags": [
          "app-installer-titles"
        ]
      }
    },
    "/v1/app-installers/titles/{id}": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInstallerTitle"
                }
              }
            },
            "description": "Successful response"
          },
          "404": {
            "description": "Title not found"
          }
        },
        "summary": "Get an App Installer title by ID",
        "tags": [
          "app-installer-titles"
        ]
      }
    }
  }
}
