{
  "components": {
    "parameters": {
      "DeviceId": {
        "description": "The ID of the device, in UUID format",
        "example": "616e6479-6973-6173-7461-6c6c696f6e21",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      },
      "tenantId": {
        "description": "The tenant UUID identifier",
        "in": "path",
        "name": "tenantId",
        "required": true,
        "schema": {
          "example": "e77c1408-10c8-4007-b177-abc9157fbcaa",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ApiError": {
        "properties": {
          "errors": {
            "items": {
              "properties": {
                "code": {
                  "description": "Error-specific code that can be used to identify localization string, etc.",
                  "example": "INVALID_FIELD",
                  "type": "string"
                },
                "description": {
                  "description": "A general description of error for troubleshooting/debugging. Generally this text should not be displayed to a user; instead refer to errorCode and its localized text",
                  "example": "I've just picked up a fault in the AE35 unit. It's going to go 100% failure in 72 hours",
                  "type": "string"
                },
                "field": {
                  "description": "Name of the field that caused the error.",
                  "example": "Name",
                  "type": "string"
                },
                "id": {
                  "description": "id of object with error. Optional.",
                  "example": "3",
                  "type": "string"
                }
              },
              "required": [
                "code",
                "field",
                "description"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "httpStatus": {
            "description": "HTTP status of the response",
            "example": 400,
            "type": "integer"
          },
          "traceId": {
            "example": "ecf2ca07e23c0abc12393472f2b783df",
            "type": "string"
          }
        },
        "required": [
          "httpStatus",
          "traceId",
          "errors"
        ],
        "type": "object"
      },
      "DeviceCommandResponse": {
        "properties": {
          "commandId": {
            "description": "The ID of the command that was created to perform the requested action",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          },
          "deviceId": {
            "description": "The ID of the device to which the command was sent",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "deviceId",
          "commandId"
        ],
        "type": "object"
      },
      "EraseDeviceRequest": {
        "properties": {
          "clearActivationLock": {
            "default": false,
            "description": "Clear the activation lock on the device. Applies to mobile devices only.\n",
            "example": true,
            "type": "boolean"
          },
          "disallowProximitySetup": {
            "default": false,
            "description": "If 'true', disable Proximity Setup on the next reboot and skip the pane in Setup Assistant. Applies to mobile devices only.\n",
            "example": true,
            "type": "boolean"
          },
          "pin": {
            "description": "The six-character PIN for Find My. Applies to computers only.\n",
            "example": "123456",
            "maximum": 6,
            "minimum": 6,
            "nullable": true,
            "type": "string"
          },
          "preserveDataPlan": {
            "default": false,
            "description": "If 'true', preserve the data plan on an iPhone or iPad with eSIM functionality, if one exists. Applies to mobile devices only.\n",
            "example": true,
            "type": "boolean"
          },
          "returnToService": {
            "default": false,
            "description": "If 'true', the device will be returned to service after the erase is complete. Applies to mobile devices only.\n",
            "example": true,
            "type": "boolean"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "description": "JWT Bearer token authentication. Obtain a token from the Jamf API Gateway.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Jamf Developer",
      "url": "https://developer.jamf.com"
    },
    "description": "API for invoking common management tasks against managed devices",
    "termsOfService": "https://www.jamf.com/developer-resources/api-license-agreement/",
    "title": "Device Management Actions API",
    "version": "1.0.0"
  },
  "openapi": "3.0.1",
  "paths": {
    "/v1/tenant/{tenantId}/devices/{id}/check-in": {
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceId"
        }
      ],
      "post": {
        "description": "Requests that a device check for pending commands\n\n**Required Permissions:** `execute:pro:device-actions`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Device check in requested successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The requested device could not be found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The specified device cannot receive a check in request. This is typically because the device is unmanaged."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Request a device check in",
        "tags": [
          "device-actions"
        ],
        "x-action": true,
        "x-authentication-required": true,
        "x-required-privileges": [
          "execute:pro:device-actions"
        ]
      }
    },
    "/v1/tenant/{tenantId}/devices/{id}/erase": {
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceId"
        }
      ],
      "post": {
        "description": "Requests that a device erase its content and settings\n\n**Required Permissions:** `execute:pro:device-actions`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EraseDeviceRequest"
              }
            }
          },
          "description": "Additional options for erasing the device"
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DeviceCommandResponse"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Device erase requested successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The requested device could not be found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The specified device cannot be erased. This is typically because the device is unmanaged or personal."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Erase a device",
        "tags": [
          "device-actions"
        ],
        "x-action": true,
        "x-authentication-required": true,
        "x-required-privileges": [
          "execute:pro:device-actions"
        ]
      }
    },
    "/v1/tenant/{tenantId}/devices/{id}/restart": {
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceId"
        }
      ],
      "post": {
        "description": "Requests that a device restart\n\n**Required Permissions:** `execute:pro:device-actions`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DeviceCommandResponse"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Device restart requested successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The requested device could not be found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The specified device cannot be restarted. This is typically because the device is unmanaged, personal, or running an OS version that does not support the restart command."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Restart a device",
        "tags": [
          "device-actions"
        ],
        "x-action": true,
        "x-authentication-required": true,
        "x-required-privileges": [
          "execute:pro:device-actions"
        ]
      }
    },
    "/v1/tenant/{tenantId}/devices/{id}/shutdown": {
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceId"
        }
      ],
      "post": {
        "description": "Requests that a device shut down\n\n**Required Permissions:** `execute:pro:device-actions`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DeviceCommandResponse"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Device shutdown requested successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The requested device could not be found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The specified device cannot be shut down. This is typically because the device is unmanaged, personal, or running an OS version that does not support the shutdown command."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Shut down a device",
        "tags": [
          "device-actions"
        ],
        "x-action": true,
        "x-authentication-required": true,
        "x-required-privileges": [
          "execute:pro:device-actions"
        ]
      }
    },
    "/v1/tenant/{tenantId}/devices/{id}/unmanage": {
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceId"
        }
      ],
      "post": {
        "description": "Removes remote management from a device\n\n**Required Permissions:** `execute:pro:device-actions`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DeviceCommandResponse"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Device unmanage requested successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The requested device could not be found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "The specified device cannot be unmanaged. This is typically because the device is already unmanaged."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Unmanage a device",
        "tags": [
          "device-actions"
        ],
        "x-action": true,
        "x-authentication-required": true,
        "x-required-privileges": [
          "execute:pro:device-actions"
        ]
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "servers": [
    {
      "description": "Jamf Beta API Gateway - prod",
      "url": "https://{region}.apigw.jamf.com/api/device-actions",
      "variables": {
        "region": {
          "default": "us",
          "description": "Geographic deployment region",
          "enum": [
            "us",
            "eu",
            "apac"
          ]
        }
      }
    }
  ]
}
