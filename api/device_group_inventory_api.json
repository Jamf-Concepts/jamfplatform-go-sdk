{
  "components": {
    "parameters": {
      "DeviceGroupId": {
        "description": "The ID of the device group, in UUID format",
        "example": "616e6479-6973-6173-7461-6c6c696f6e21",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      },
      "DeviceId": {
        "description": "The ID of the device, in UUID format",
        "example": "616e6479-6973-6173-7461-6c6c696f6e21",
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      },
      "PageIndex": {
        "description": "Page number (0-based)",
        "in": "query",
        "name": "page",
        "schema": {
          "default": 0,
          "format": "int32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "PageSize": {
        "description": "Number of items per page",
        "in": "query",
        "name": "page-size",
        "schema": {
          "default": 100,
          "format": "int32",
          "minimum": 1,
          "type": "integer"
        }
      },
      "Sort": {
        "description": "Fields to sort by and their orders.\u003c/br\u003e Fields allowed for sorting: `name`, `description`, `deviceType`, `groupType`.",
        "example": "name,description:desc",
        "in": "query",
        "name": "sort",
        "schema": {
          "default": "name",
          "type": "string"
        }
      },
      "tenantId": {
        "description": "The tenant UUID identifier",
        "in": "path",
        "name": "tenantId",
        "required": true,
        "schema": {
          "example": "e77c1408-10c8-4007-b177-abc9157fbcaa",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ApiErrorCauseRepresentation": {
        "properties": {
          "code": {
            "description": "Error-specific code that can be used to identify localization string, etc.",
            "example": "INVALID_FIELD",
            "type": "string"
          },
          "description": {
            "description": "A general description of error for troubleshooting/debugging. Generally this text should not be displayed to a user; instead refer to errorCode and its localized text",
            "example": "I've just picked up a fault in the AE35 unit. It's going to go 100% failure in 72 hours",
            "type": "string"
          },
          "field": {
            "description": "Name of the field that caused the error.",
            "example": "Name",
            "type": "string"
          },
          "id": {
            "description": "id of object with error. Optional.",
            "example": "3",
            "type": "string"
          }
        },
        "required": [
          "code",
          "field",
          "description"
        ],
        "type": "object"
      },
      "ApiErrorRepresentation": {
        "properties": {
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ApiErrorCauseRepresentation"
            },
            "type": "array"
          },
          "httpStatus": {
            "description": "HTTP status of the response",
            "example": 400,
            "type": "integer"
          },
          "traceId": {
            "example": "ecf2ca07e23c0abc12393472f2b783df",
            "type": "string"
          }
        },
        "required": [
          "httpStatus",
          "traceId",
          "errors"
        ],
        "type": "object"
      },
      "DeviceGroupCreateRepresentationV1": {
        "properties": {
          "criteria": {
            "default": [],
            "description": "The criteria used to calculate the group's members. Can only be used if `groupType` is `SMART`.\n",
            "items": {
              "$ref": "#/components/schemas/DeviceGroupCriteriaRepresentationV1"
            },
            "type": "array"
          },
          "description": {
            "default": "",
            "description": "Description of the device group",
            "example": "A custom group of devices",
            "type": "string"
          },
          "deviceType": {
            "$ref": "#/components/schemas/DeviceTypeV1"
          },
          "groupType": {
            "$ref": "#/components/schemas/GroupTypeV1"
          },
          "members": {
            "default": [],
            "description": "The IDs of the devices to be added to the group, in UUID format. Can only be used if `groupType` is `STATIC`.\n",
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "Name of the device group",
            "example": "New Device Group",
            "type": "string"
          }
        },
        "required": [
          "name",
          "deviceType",
          "groupType"
        ],
        "type": "object"
      },
      "DeviceGroupCriteriaRepresentationV1": {
        "properties": {
          "attributeName": {
            "description": "Name of the attribute used in the criteria",
            "example": "Device Name",
            "type": "string"
          },
          "attributeValue": {
            "description": "Value of the attribute used in the criteria",
            "example": "Some Device Name",
            "type": "string"
          },
          "hasClosingParenthesis": {
            "default": false,
            "description": "Indicates if the criteria ends with a closing parenthesis",
            "type": "boolean"
          },
          "hasOpeningParenthesis": {
            "default": false,
            "description": "Indicates if the criteria starts with an opening parenthesis",
            "type": "boolean"
          },
          "joinType": {
            "$ref": "#/components/schemas/JoinTypeV1"
          },
          "operator": {
            "description": "Operator used for the criteria",
            "example": "IS",
            "type": "string"
          },
          "order": {
            "description": "Order of the criteria in the group. All criteria must have a unique, sequential order starting from 0.\n",
            "example": 0,
            "type": "integer"
          }
        },
        "required": [
          "order",
          "attributeName",
          "operator",
          "attributeValue",
          "joinType"
        ],
        "type": "object"
      },
      "DeviceGroupListReadRepresentationV1": {
        "properties": {
          "description": {
            "default": "",
            "description": "Description of the device group",
            "example": "A custom group of devices",
            "type": "string"
          },
          "deviceType": {
            "$ref": "#/components/schemas/DeviceTypeV1"
          },
          "groupType": {
            "$ref": "#/components/schemas/GroupTypeV1"
          },
          "id": {
            "description": "The ID of the device group, in UUID format",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          },
          "memberCount": {
            "default": 0,
            "description": "Number of devices in the group",
            "type": "integer"
          },
          "name": {
            "description": "Name of the device group",
            "example": "Some Device Group",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "deviceType",
          "groupType",
          "memberCount"
        ],
        "type": "object"
      },
      "DeviceGroupMemberOfRepresentationV1": {
        "properties": {
          "groupId": {
            "description": "The ID of the device group, in UUID format",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          },
          "groupName": {
            "description": "Name of the device group",
            "example": "Some Device Group",
            "type": "string"
          }
        },
        "required": [
          "groupId",
          "groupName"
        ],
        "type": "object"
      },
      "DeviceGroupMemberPatchRepresentationV1": {
        "properties": {
          "added": {
            "default": [],
            "description": "List of device IDs to be added to the group, in UUID format",
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "type": "array"
          },
          "removed": {
            "default": [],
            "description": "List of device IDs to be removed from the group, in UUID format",
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "DeviceGroupReadRepresentationV1": {
        "properties": {
          "criteria": {
            "description": "Criteria used to calculate the group's members, if applicable",
            "items": {
              "$ref": "#/components/schemas/DeviceGroupCriteriaRepresentationV1"
            },
            "nullable": true,
            "type": "array"
          },
          "description": {
            "default": "",
            "description": "Description of the device group",
            "example": "A custom group of devices",
            "type": "string"
          },
          "deviceType": {
            "$ref": "#/components/schemas/DeviceTypeV1"
          },
          "groupType": {
            "$ref": "#/components/schemas/GroupTypeV1"
          },
          "id": {
            "description": "The ID of the device group, in UUID format",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          },
          "memberCount": {
            "default": 0,
            "description": "Number of devices in the group",
            "type": "integer"
          },
          "name": {
            "description": "Name of the device group",
            "example": "Some Device Group",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "deviceType",
          "groupType",
          "memberCount"
        ],
        "type": "object"
      },
      "DeviceGroupUpdateRepresentationV1": {
        "properties": {
          "criteria": {
            "default": [],
            "description": "The criteria used to calculate the group's members. Can only be used if `groupType` is `SMART`.\n",
            "items": {
              "$ref": "#/components/schemas/DeviceGroupCriteriaRepresentationV1"
            },
            "type": "array"
          },
          "description": {
            "default": "",
            "description": "Description of the device group",
            "example": "A custom group of devices",
            "type": "string"
          },
          "name": {
            "description": "Name of the device group",
            "example": "Some Device Group",
            "type": "string"
          }
        },
        "type": "object"
      },
      "DeviceTypeV1": {
        "description": "Type of device",
        "enum": [
          "COMPUTER",
          "MOBILE"
        ],
        "type": "string"
      },
      "GroupTypeV1": {
        "description": "Type of the device group",
        "enum": [
          "SMART",
          "STATIC"
        ],
        "type": "string"
      },
      "HrefRepresentation": {
        "properties": {
          "href": {
            "description": "URL of the resource",
            "example": "/v1/device-groups/616e6479-6973-6173-7461-6c6c696f6e21",
            "type": "string"
          },
          "id": {
            "description": "The ID of the resource, in UUID format",
            "example": "616e6479-6973-6173-7461-6c6c696f6e21",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id",
          "href"
        ],
        "type": "object"
      },
      "JoinTypeV1": {
        "description": "Type of join for criteria",
        "enum": [
          "AND",
          "OR"
        ],
        "type": "string"
      },
      "ListDeviceGroupMemberOfResponseRepresentation": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ListResponseRepresentation"
          },
          {
            "properties": {
              "results": {
                "description": "List of device groups for the specified device",
                "items": {
                  "$ref": "#/components/schemas/DeviceGroupMemberOfRepresentationV1"
                },
                "type": "array"
              }
            },
            "required": [
              "results"
            ],
            "type": "object"
          }
        ]
      },
      "ListDeviceGroupMemberReadRepresentation": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ListResponseRepresentation"
          },
          {
            "properties": {
              "results": {
                "description": "List of device group members",
                "example": [
                  "616e6479-6973-6173-7461-6c6c696f6e21",
                  "616e6479-6973-6173-7461-6c6c696f6e22"
                ],
                "items": {
                  "format": "uuid",
                  "type": "string"
                },
                "type": "array"
              }
            },
            "required": [
              "results"
            ],
            "type": "object"
          }
