    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "description": "JWT Bearer token authentication. Obtain a token from the Jamf API Gateway.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Jamf Developer",
      "url": "https://developer.jamf.com"
    },
    "description": "Management API for Device Groups - Create, manage, and organize device groups with membership controls",
    "termsOfService": "https://www.jamf.com/developer-resources/api-license-agreement/",
    "title": "Device Groups API",
    "version": "1.0.0"
  },
  "openapi": "3.0.1",
  "paths": {
    "/v1/tenant/{tenantId}/device-groups": {
      "get": {
        "description": "Retrieve a paginated list of all device groups for the tenant\n\n**Required Permissions:** `read:pro:device-groups`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/PageIndex"
          },
          {
            "$ref": "#/components/parameters/PageSize"
          },
          {
            "$ref": "#/components/parameters/Sort"
          },
          {
            "description": "Filter query in RSQL format. Includes all results, by default.\u003c/br\u003e Fields allowed in the query: `name`, `description`, `deviceType`, `groupType`.\u003c/br\u003e This param can be combined with paging.\u003c/br\u003e Example: `name==\"*Managed*\" and deviceType==\"MOBILE\"`",
            "in": "query",
            "name": "filter",
            "schema": {
              "default": "",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedDeviceGroupResponseRepresentation"
                }
              }
            },
            "description": "Paginated list of device groups"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get all device groups",
        "tags": [
          "device-groups"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:device-groups"
        ]
      },
      "post": {
        "description": "Create a new device group in Jamf Pro\n\n**Required Permissions:** `create:pro:device-groups`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceGroupCreateRepresentationV1"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HrefRepresentation"
                }
              }
            },
            "description": "Device group created successfully"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorRepresentation"
                }
              }
            },
            "description": "Device group already exists"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create a new device group",
        "tags": [
          "device-groups"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "create:pro:device-groups"
        ]
      }
    },
    "/v1/tenant/{tenantId}/device-groups/{id}": {
      "delete": {
        "description": "Delete an existing device group\n\n**Required Permissions:** `delete:pro:device-groups`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Device group deleted successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorRepresentation"
                }
              }
            },
            "description": "The requested device group could not be found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Delete a device group",
        "tags": [
          "device-groups"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "delete:pro:device-groups"
        ]
      },
      "get": {
        "description": "Retrieve a specific device group by its ID\n\n**Required Permissions:** `read:pro:device-groups`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceGroupReadRepresentationV1"
                }
              }
            },
            "description": "Device group found"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorRepresentation"
                }
              }
            },
            "description": "The requested device group could not be found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a device group by ID",
        "tags": [
          "device-groups"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:pro:device-groups"
        ]
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/DeviceGroupId"
        }
      ],
      "patch": {
        "description": "Update an existing device group\n\n**Required Permissions:** `update:pro:device-groups`",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "description": "Path parameter id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
