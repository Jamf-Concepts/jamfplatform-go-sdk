                "$ref": "#/components/schemas/DeviceGroupUpdateRepresentationV1"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Device group updated successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorRepresentation"
                }
              }
            },
            "description": "The requested device group could not be found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Update a device group",
        "tags": [
          "device-groups"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "update:pro:device-groups"
        ]
      }
    },
