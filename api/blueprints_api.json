  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "openapi": "3.0.1",
  "paths": {
    "/v1/blueprint-components": {
      "get": {
        "description": "Get list of available blueprint components",
        "operationId": "listComponents",
        "parameters": [
          {
            "description": "Zero-based page index (0..N)",
            "in": "query",
            "name": "page",
            "schema": {
              "default": 0,
              "format": "int32",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "The size of the page to be returned",
            "in": "query",
            "name": "page-size",
            "schema": {
              "default": 100,
              "format": "int32",
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponseComponentDescription"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List available blueprint components",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:blueprints",
          "read:pro:blueprints",
          "read:school:blueprints"
        ]
      }
    },
    "/v1/blueprint-components/{identifier}": {
      "get": {
        "description": "Get component by identifier",
        "operationId": "getComponent",
        "parameters": [
          {
            "description": "Identifier of the component",
            "in": "path",
            "name": "identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComponentDescription"
                }
              }
            },
            "description": "Blueprint component was found"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint component was not found"
          }
        },
        "summary": "Get component",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:blueprints",
          "read:pro:blueprints",
          "read:school:blueprints"
        ]
      }
    },
    "/v1/blueprints": {
      "get": {
        "description": "Get list of blueprints",
        "operationId": "listBlueprints",
        "parameters": [
          {
            "description": "Zero-based page index (0..N)",
            "in": "query",
            "name": "page",
            "schema": {
              "default": 0,
              "format": "int32",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "The size of the page to be returned",
            "in": "query",
            "name": "page-size",
            "schema": {
              "default": 100,
              "format": "int32",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Sorting criteria in the format: `\u003cfield_name\u003e[:sort_direction][,\u003csecondary_sort_field_name\u003e[:sort_direction]]*`. Default sort direction is `asc` (Ascending). Use `desc` for Descending ordering. Additional sort parameters are supported and determine order of results that have equivalent values for previous sort parameters.",
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "created:desc",
              "type": "string"
            }
          },
          {
            "description": "Search query to match against `name` and `description` properties.",
            "in": "query",
            "name": "search",
            "schema": {
              "description": "Search query to match against `name` and `description` properties.",
              "maxLength": 1000,
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponseBlueprintOverview"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "List blueprints",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:blueprints",
          "read:pro:blueprints",
          "read:school:blueprints"
        ]
      },
      "post": {
        "description": "Create a new blueprint",
        "operationId": "createBlueprint",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBlueprintRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateResponse"
                }
              }
            },
            "description": "Blueprint was successfully created",
            "headers": {
              "Location": {
                "description": "URL of the created blueprint",
                "schema": {
                  "format": "uri",
                  "type": "string"
                },
                "style": "simple"
              }
            }
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint is invalid"
          }
        },
        "summary": "Create a new blueprint",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "create:env:blueprints",
          "create:pro:blueprints",
          "create:school:blueprints"
        ]
      }
    },
    "/v1/blueprints/{blueprintId}": {
      "delete": {
        "description": "Delete a blueprint",
        "operationId": "deleteBlueprint",
        "parameters": [
          {
            "description": "Blueprint ID",
            "in": "path",
            "name": "blueprintId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Blueprint was successfully deleted"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint wasn't found"
          }
        },
        "summary": "Delete a blueprint",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "delete:env:blueprints",
          "delete:pro:blueprints",
          "delete:school:blueprints"
        ]
      },
      "get": {
        "description": "Get a blueprint",
        "operationId": "getBlueprint",
        "parameters": [
          {
            "description": "Blueprint ID",
            "in": "path",
            "name": "blueprintId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlueprintDetail"
                }
              }
            },
            "description": "Blueprint was fetched successfully"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint doesn't exist"
          }
        },
        "summary": "Get a blueprint",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "read:env:blueprints",
          "read:pro:blueprints",
          "read:school:blueprints"
        ]
      },
      "patch": {
        "description": "Updates a blueprint configuration.",
        "operationId": "patchBlueprint",
        "parameters": [
          {
            "description": "Blueprint ID",
            "in": "path",
            "name": "blueprintId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/merge-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBlueprintRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Blueprint was successfully updated"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint update is not valid"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Blueprint wasn't found"
          }
        },
        "summary": "Updates a blueprint configuration",
        "tags": [
          "blueprints"
        ],
        "x-authentication-required": true,
        "x-required-privileges": [
          "update:env:blueprints",
          "update:pro:blueprints",
          "update:school:blueprints"
        ]
      }
    },
    "/v1/blueprints/{blueprintId}/deploy": {
      "post": {
        "description": "Deploy blueprint",
        "operationId": "deployBlueprint",
        "parameters": [
          {
            "description": "Blueprint ID",
            "in": "path",
            "name": "blueprintId",
